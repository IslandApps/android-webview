<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Progress Bar Style -->
    <style name="ProgressBarStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:max">100</item>
        <item name="android:progressTint">@color/progress_bar_color</item>
    </style>

    <!-- Error View Style -->
    <style name="ErrorViewStyle">
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">24dp</item>
        <item name="android:background">@color/background_primary</item>
    </style>

    <!-- Error Title Style -->
    <style name="ErrorTitleStyle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/error_color</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <!-- Error Message Style -->
    <style name="ErrorMessageStyle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <!-- Retry Button Style -->
    <style name="RetryButtonStyle" parent="Widget.Material3.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:text">@string/retry</item>
        <item name="backgroundTint">@color/primary_color</item>
        <item name="android:textColor">@android:color/white</item>
    </style>
</resources>
